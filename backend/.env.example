# ============================================================
# Evoco Backend — Environment Variables
# Copy to .env and fill in real values before starting.
# ============================================================

# ---- AWS Credentials (required for Bedrock / Nova models) ----
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# ---- Amazon Nova Act ----
NOVA_ACT_API_KEY=your_nova_act_api_key

# ---- App Settings ----
APP_ENV=development          # development | production
APP_PORT=8000
APP_HOST=0.0.0.0

# ---- CORS (comma-separated allowed origins) ----
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ---- Browser Automation ----
HEADLESS_BROWSER=true
MAX_CONCURRENT_BROWSERS=3
BROWSER_TIMEOUT_SECONDS=60

# ---- Pipeline ----
PIPELINE_TIMEOUT_SECONDS=300   # hard cap per task (5 minutes)

# ---- Rate Limits ----
MAX_TASKS_PER_MINUTE=10
MAX_CONCURRENT_TASKS=5

# ---- Redis (leave blank to use in-memory fallback) ----
REDIS_URL=redis://localhost:6379/0

# ---- Authentication (JWT) ----
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ---- Result Cache ----
# TTL in seconds for caching completed task results (0 = disabled)
RESULT_CACHE_TTL_SECONDS=3600
